# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# better-auth
BETTER_AUTH_SECRET=change-me-32-char-secret-minimum-32c
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stellar x402 — self-hosted facilitator
STELLAR_FACILITATOR_URL=http://localhost:3000/api/facilitator
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Facilitator secret key (used to sign x402 settlement transactions on Stellar testnet)
FACILITATOR_SECRET_KEY=

# Safety guardrail — max USDC any single payer can spend in a 1-hour window
MAX_PAYER_SPEND_PER_HOUR_USDC=1.0

# Soroban EndpointRegistry contract (optional — leave blank to skip on-chain anchoring)
REGISTRY_CONTRACT_ID=
REGISTRY_SUBMITTER_SECRET=
